#!/bin/sh
# shellcheck disable=SC1091  # lib files are sourced via $FSS_HOME and linted individually
# fss — A Fast Security Scan for developers.
#
# Scans Node.js projects for security issues and supply-chain attack
# indicators, cleans node_modules safely, and flags outdated dependencies.
# POSIX sh only: runs on macOS (sh/bash) and Debian-based Linux (dash).
#
# Usage: fss <command> [dir] [options]
set -u

# Resolve $0 through symlinks (install.sh links ~/.local/bin/fss here) so
# FSS_HOME points at the real install dir, not the symlink's parent.
SELF="$0"
while [ -h "$SELF" ]; do
  LINK="$(readlink "$SELF")"
  case "$LINK" in
    /*) SELF="$LINK" ;;
    *) SELF="$(dirname -- "$SELF")/$LINK" ;;
  esac
done
FSS_HOME="$(CDPATH='' cd -- "$(dirname -- "$SELF")/.." && pwd)"

# shellcheck source=../lib/common.sh
. "$FSS_HOME/lib/common.sh"

usage() {
  cat <<EOF
${BLD}fss${RST} $FSS_VERSION — A Fast Security Scan for developers.

Usage: fss <command> [dir] [options]

Commands:
  scan [dir]                Scan for security issues and supply-chain
                            attack indicators (default dir: .)
  clean [dir] [--dry-run] [--yes]
                            Find and safely delete node_modules directories
  outdated [dir]            Check dependency versions against the npm registry

Options:
  -h, --help                Show this help
  -v, --version             Show version

Environment:
  NO_COLOR=1                Disable colored output
  FSS_OFFLINE=1             Skip registry lookups in 'outdated'
  FSS_NO_ANIMATION=1        Disable the welcome banner animation

Exit codes:
  scan:     0 clean, 1 warnings, 2 critical findings, 3 error
  clean:    0 success, 3 error
  outdated: 0 all current, 1 outdated found, 3 error
EOF
}

# Bare `fss`: animated welcome banner (logo + info box + usage), like sak.
if [ $# -eq 0 ]; then
  . "$FSS_HOME/lib/banner.sh"
  render_banner
  exit 0
fi

cmd="$1"
shift

case "$cmd" in
  scan)
    . "$FSS_HOME/lib/scan.sh"
    cmd_scan "$@"
    ;;
  clean)
    . "$FSS_HOME/lib/clean.sh"
    cmd_clean "$@"
    ;;
  outdated)
    . "$FSS_HOME/lib/outdated.sh"
    cmd_outdated "$@"
    ;;
  -h|--help|help)
    usage
    ;;
  -v|--version|version)
    printf '%s\n' "$FSS_VERSION"
    ;;
  *)
    printf 'fss: unknown command: %s\n\n' "$cmd" >&2
    usage
    exit 3
    ;;
esac
